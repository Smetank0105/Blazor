@page "/todo"
@rendermode InteractiveServer
@using TODOlist.Classes

<PageTitle>TODO</PageTitle>

<h3>TODO:</h3>
<div class="statistics">
    <div>Всего: @todos.Count</div>
    <div>Выполнено: @todos.Where(task => task.isDone == true).Count()</div>
    <div>Запланировано: @todos.Where(t => t.isDone == false).Count()</div>
</div>

<input type="text" placeholder="Что вы хотите сделать?" @bind="task" @onkeyup='(KeyboardEventArgs e) => { if(e.Key == "Enter")AddTask();}' />
<button @onclick="AddTask">Добавить</button>

<ul>
    @foreach(TODOitem i in todos)
    {
        <li class=@(i.isDone ? "complite-task" : "") >
            <input type="checkbox" @bind="i.isDone" id=@i.GetHashCode().ToString() />
            <label for=@i.GetHashCode().ToString()>@i.Title</label>
            <button class="delete" @onclick='()=>todos.Remove(i)' >❌</button>
        </li>
    }
</ul>