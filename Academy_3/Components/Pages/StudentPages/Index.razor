@page "/students"
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.QuickGrid
@using Academy_3.Components.Models
@using Academy_3.Data
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject IDbContextFactory<Academy_3.Data.Academy_3Context> DbFactory

<PageTitle>Index</PageTitle>

<h1>Количество студентов: @context.Students.Count()</h1>

<p>
    <a href="students/create">Create New</a>
</p>

<QuickGrid Class="table" Items="Students">
    <PropertyColumn Sortable="true" Property="student => student.last_name" />
    <PropertyColumn Sortable="true" Property="student => student.first_name" />
    <PropertyColumn Sortable="true" Property="student => student.middle_name" />
    <PropertyColumn Sortable="true" Property="student => student.birth_date" />
    @* <PropertyColumn Sortable="true" Property="student => student.Age" /> *@
    <TemplateColumn Title="Age" Sortable="true" SortBy="ageSort" >@context.Age</TemplateColumn>
@*     <PropertyColumn Property="student => student.email" />
    <PropertyColumn Property="student => student.phone" />
    <PropertyColumn Property="student => student.photo" /> *@
    <PropertyColumn Sortable="true" Property="student => student.Group.group_name" />

    <TemplateColumn Context="student">
        @* <a href="@($"students/edit?stud_id={student.stud_id}")">Edit</a> | *@
        <a href="@($"students/details?stud_id={student.stud_id}")">Details</a>
        @* <a href="@($"students/delete?stud_id={student.stud_id}")">Delete</a> *@
    </TemplateColumn>
</QuickGrid>

@code {
    private Academy_3Context context = default!;
    IQueryable<Student> Students = default!;
    GridSort<Student> ageSort = GridSort<Student>.ByDescending(s => s.birth_date);

    protected override void OnInitialized()
    {
        context = DbFactory.CreateDbContext();
        Students = context.Students.Include(s => s.Group);
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}
